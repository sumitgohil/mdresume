---
import { parseResume } from "@/lib/resumeParser";

type Props = {
  markdown: string;
  themeId?: string;
  compact?: boolean;
};

const { markdown, themeId = "modern-pro", compact = false } = Astro.props;
const parsed = parseResume(markdown);
const contentLines = parsed.content
  .split("\n")
  .map((line) => line.trim())
  .filter(Boolean);
---

<article class:list={["resume-paper", `theme-${themeId}`, compact && "compact-preview"]}>
  {parsed.data.name && (compact ? <div class="resume-name">{parsed.data.name}</div> : <h1>{parsed.data.name}</h1>)}
  {(parsed.data.title || parsed.data.email || parsed.data.location) && (
    <p class="resume-meta">
      {[parsed.data.title, parsed.data.email, parsed.data.location].filter(Boolean).join(" | ")}
    </p>
  )}
  {
    contentLines.slice(0, compact ? 16 : 28).map((line) => {
      if (line.startsWith("## ")) return <h2>{line.replace("## ", "")}</h2>;
      if (line.startsWith("### ")) return <h3>{line.replace("### ", "")}</h3>;
      if (line.startsWith("- ")) return <p>• {line.replace("- ", "")}</p>;
      if (line.startsWith("**")) return <p><strong>{line.replaceAll("**", "")}</strong></p>;
      return <p>{line.replaceAll("**", "")}</p>;
    })
  }
</article>
