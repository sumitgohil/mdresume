---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
  title="Blog"
  description="Notes on building MDResume, Markdown resume workflows, open-source frontend architecture, and resume presentation."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Blog</span>
      <h1>Build notes and resume writing workflows.</h1>
      <p>
        Short articles covering the product architecture, Markdown workflow, SEO-first Astro pages, and practical resume
        structure.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      {posts.map((post) => (
        <article class="blog-card">
          <span class="eyebrow">{post.data.publishDate.toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}</span>
            <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="tag-list">
            {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
