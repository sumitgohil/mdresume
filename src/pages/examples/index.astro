---
import ResumePreview from "@/components/ResumePreview.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { examples, findTemplate } from "@/data/resume";
---

<BaseLayout
  title="Resume Examples"
  description="Study detailed resume examples for software engineers, frontend engineers, backend engineers, product managers, and early-career developers."
  imageAlt="MDResume resume examples gallery preview"
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Example Resumes</span>
      <h1>Resume examples for real hiring conversations</h1>
      <p>
        Start with role-specific Markdown samples that show structure, scope, measurable outcomes, and clean formatting.
        Use the <a href="/ai-resume">AI resume review workflow</a> to compare an example against a job description.
      </p>
    </div>
  </section>

  <section class="section border-top">
    <div class="container grid three examples-grid">
      {examples.map((example) => {
        const template = findTemplate(example.templateId);
        return (
          <article class="template-card example-preview-card">
            <div class="paper-wrap">
              <ResumePreview markdown={example.markdown} themeId={template.themeId} compact />
            </div>
            <div class="template-card-body">
              <span class="mini-label">{example.role}</span>
              <h3>{example.title}</h3>
              <p>{example.summary}</p>
              <div class="tag-list">
                {example.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <div class="card-action-row">
                <span class="template-audience">
                  Layout: <strong>{template.name}</strong>
                </span>
                <a class="card-cta-btn" href={`/editor?example=${example.id}`}>
                  Edit example ->
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
